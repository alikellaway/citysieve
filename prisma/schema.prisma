generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  emailOptIn       Boolean   @default(true)
  termsAcceptedAt  DateTime?
  termsVersion     String?

  accounts     Account[]
  sessions     Session[]
  savedSurveys SavedSurvey[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedSurvey {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Untitled Survey")
  state     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SurveyAnalytics {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  userId          String?
  surveyMode      String?
  surveyState     String
  topResults      String
  totalCandidates Int
  rejectedCount   Int
  passedCount     Int
  radiusKm        Int
}

model AreaCentroid {
  id      String @id @default(cuid())
  type    String // e.g. "outcode"
  name    String // e.g. "M4 5"
  outcode String
  lat     Float
  lng     Float

  @@index([lat, lng])
  @@index([outcode])
}

model School {
  id           Int     @id @default(autoincrement())
  urn          String  @unique
  name         String
  lat          Float
  lng          Float
  ofstedRating Int?    // 1=Outstanding, 2=Good, 3=Requires improvement, 4=Inadequate, null=unrated
  phase        String? // Primary, Secondary, etc.

  @@index([lat, lng])
}

